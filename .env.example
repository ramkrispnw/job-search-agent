# .env.example — copy to .env and fill in your values
# This file is safe to commit. .env is gitignored.

# ── Required for ATS auto-apply ───────────────────────────────────────────────
# Your contact info used to fill application forms

APPLICANT_EMAIL=you@example.com
APPLICANT_PHONE=+1-206-555-0100
APPLICANT_LINKEDIN=https://www.linkedin.com/in/yourprofile

# ── Optional: override Anthropic API key here instead of setup wizard ─────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Puppeteer settings ─────────────────────────────────────────────
# Set to "true" to watch the browser during ATS apply (useful for debugging)
PUPPETEER_HEADFUL=false

# ── Optional: run-specific overrides ─────────────────────────────────────────
# Override max jobs shortlisted (default: 5)
MAX_JOBS=5

# Only apply to jobs with alignment score >= this threshold (default: 8)
AUTO_APPLY_MIN_SCORE=8
